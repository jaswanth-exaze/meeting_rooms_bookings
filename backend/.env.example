PORT=4000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=meeting_room_booking

# Comma-separated frontend origins. Wildcard "*" is not allowed.
CORS_ORIGIN=http://localhost:4000,http://127.0.0.1:4000,http://localhost:5500,http://127.0.0.1:5500

# JWT settings (must be at least 32 random characters)
JWT_SECRET=replace_with_minimum_32_characters_random_value
JWT_EXPIRES_IN=2h

# Auth cookie settings
AUTH_COOKIE_NAME=mrb_auth
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_MAX_AGE=2h
